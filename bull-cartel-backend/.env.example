# ============================================
# BULL CARTEL BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

# --- Server ---
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://your-dashboard-domain.com

# --- Database (Railway/Render will auto-generate this) ---
DATABASE_URL=postgresql://user:password@host:5432/bullcartel

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# --- Vault encryption (used to encrypt broker API keys at rest) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=replace_with_64_char_hex_string_from_command_above

# --- Broker credentials are NOT stored here ---
# Each user enters their own broker API key/secret through the app UI.
# Those are encrypted with VAULT_MASTER_KEY and stored in the database,
# never in this file, never in the frontend, never in git.

# --- Zerodha (Kite Connect) app credentials (YOUR app, not user keys) ---
# Register at: https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=

# --- Angel One (SmartAPI) app credentials ---
# Register at: https://smartapi.angelbroking.com/
ANGEL_API_KEY=

# --- Dhan app credentials ---
# Register at: https://dhanhq.co/docs/
DHAN_CLIENT_ID=

# --- Shoonya (Finvasia) ---
# Register at: https://shoonya.com/api-documentation
SHOONYA_API_KEY=

# --- Binance (crypto) ---
# Create key at: https://www.binance.com/en/my/settings/api-management
# (Per-user keys are entered via UI vault, not here)

# --- Delta Exchange India ---
# Register at: https://www.delta.exchange/app/account/manageapikeys
